          {
            "call": "app.routes.checkout_total",
            "args": [{"tier": "standard"}, 100.0],
            "equals": 100.0
          },
          {
            "call": "app.routes.checkout_total",
            "args": [{"tier": "vip"}, 250.0],
            "equals": 225.0
          }
        ]
      },
      "verify_command": ["python", "-m", "unittest", "discover", "-s", "tests"],
      "max_changed_files": 2,
      "tags": ["patch", "reasoning"]
